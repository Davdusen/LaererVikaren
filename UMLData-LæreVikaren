@startuml

    hide circle
    hide empty methods
    
   ' Øger afstanden mellem kasserne
skinparam nodesep 300
skinparam ranksep 100

rectangle "Lære Vikaren " {
  class "SUBSTITUTE" <<table>> {
<<PK>> SubstituteID: Int
  {field} Name : NVarChar(50)
   {field} BirthDate: DateTime
   {field} Adress: NVarChar(200)
   {field} Email: NVarChar(100)
   {field} PhoneNumber: NVarChar(8)
   {field} <<FK>> SubjectID: Int 
  }

  class "SUBJECT" <<table>>
  {
   <<PK>> SubjectID: Int
      {field} Titel: NVarChar(100)
      {field} ClassLevel: Int
    

  }

  SUBSTITUTE "1..*" -- "1..*" SUBJECT
}
 

@enduml
